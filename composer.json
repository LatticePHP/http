{
    "name": "lattice/http",
    "description": "HTTP kernel and request handling for the LatticePHP framework",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "php",
        "framework",
        "http",
        "request",
        "response",
        "lattice"
    ],
    "homepage": "https://github.com/LatticePHP/framework",
    "support": {
        "issues": "https://github.com/LatticePHP/framework/issues",
        "source": "https://github.com/LatticePHP/http"
    },
    "require": {
        "php": "^8.4",
        "lattice/contracts": "^1.0",
        "lattice/routing": "^1.0",
        "lattice/database": "^1.0",
        "lattice/validation": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Lattice\\Http\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lattice\\Http\\Tests\\": "tests/"
        }
    }
}
